# Supabase project URL (safe to expose; used client + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (safe to expose; guarded by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server only, never send to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App canonical web origin used for Supabase magic-link callbacks
SITE_URL=http://localhost:3000

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token

# Telegram chat ID for the notification recipient
TELEGRAM_CHAT_ID=replace-with-chat-id

# Resend API key for email delivery
RESEND_API_KEY=re_your_api_key_here

# Resend verified sender address
RESEND_FROM=sunsets@yourdomain.com

# Resend recipient email address
RESEND_TO=recipient@example.com

# Cloudflare Tunnel URL for the Pi live-view endpoint
PI_LIVE_URL=https://pi.your-tunnel.example.com

# HMAC shared secret for Pi live-view request authentication
PI_SHARED_SECRET=your-random-secret-here

# Pi capture window duration in minutes
CAPTURE_WINDOW_MINUTES=90

# Minutes before sunset when the Pi starts capturing
CAPTURE_BEFORE_SUNSET_MINUTES=60

# Seconds between captured photos
CAPTURE_INTERVAL_SECONDS=180

# Days to keep non-best raw photos before purging
RAW_RETENTION_DAYS=14

# Access control (server-side only, never NEXT_PUBLIC_)
ADMIN_EMAIL=admin@example.com
RECIPIENT_EMAILS=recipient@example.com
